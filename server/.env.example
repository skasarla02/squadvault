# Copy this file to .env and fill in real values. Never commit .env.

# Neon Postgres connection string (test/dev database)
# Get one free at https://neon.tech -> create project -> copy the pooled connection string
DATABASE_URL=postgresql://user:password@ep-example-000000.us-east-2.aws.neon.tech/squadvault?sslmode=require

# Random string used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Stripe TEST MODE secret key (starts with sk_test_...). Never use a live key here.
STRIPE_SECRET_KEY=sk_test_replace_me

# Port the Express API listens on
PORT=3001

# Origin of the Vite dev server, for CORS + cookie settings in dev
CLIENT_ORIGIN=http://localhost:5173
